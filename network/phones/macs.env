# Per-phone fixed gadget MAC pairs.
# host_addr is the MAC the laptop sees on the USB tether.
# dev_addr is the MAC the phone uses for its own usb0 interface.
# Pick any locally-administered MAC (second-lowest bit of first octet = 1).

# one6t
ONE6T_HOST_ADDR=16:26:d6:df:e9:bb
ONE6T_DEV_ADDR=16:26:d6:df:e9:bc

# one62
ONE62_HOST_ADDR=9a:e8:dd:73:77:5d
ONE62_DEV_ADDR=9a:e8:dd:73:77:5e

# one61
ONE61_HOST_ADDR=f2:1c:05:01:4e:d5
ONE61_DEV_ADDR=f2:1c:05:01:4e:d6
